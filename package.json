    "prisma": "^7.8.0",
    "testcontainers": "^11.14.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
