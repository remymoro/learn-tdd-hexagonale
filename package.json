  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --reporter=verbose src/infrastructure/*.integration.spec.ts",
    "api": "tsx src/apps/api.ts",
    "api:hono": "tsx src/apps/api-hono.ts",
