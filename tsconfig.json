{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@application/*": ["libs/crafty/src/application/*"],
      "@domain/*": ["libs/crafty/src/domain/*"],
      "@infrastructure/*": ["libs/crafty/src/infrastructure/*"],
      "@shared/*": ["libs/crafty/src/shared/*"],
      "@tests/*": ["libs/crafty/src/tests/*"],
      "@builders/*": ["libs/crafty/src/tests/builders/*"],
      "@crafty/crafty": ["libs/crafty/src"],
      "@crafty/crafty/*": ["libs/crafty/src/*"],
      "@generated/*": ["generated/*"]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "libs/**/*.ts",
    "apps/**/*.ts",
    "generated/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}